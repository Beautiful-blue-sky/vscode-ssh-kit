{
  "name": "ssh-kit",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.13",
  "publisher": "lixiaoyu",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Beautiful-blue-sky/vscode-ssh-kit"
  },
  "homepage": "https://github.com/Beautiful-blue-sky/vscode-ssh-kit#readme",
  "bugs": {
    "url": "https://github.com/Beautiful-blue-sky/vscode-ssh-kit/issues"
  },
  "keywords": [
    "ssh",
    "remote",
    "remote-ssh",
    "server",
    "devops",
    "ssh-config",
    "key-management"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "languageModelTools": [
      {
        "name": "sshKit_listHosts",
        "tags": [
          "ssh",
          "remote",
          "devops"
        ],
        "toolReferenceName": "sshKitHosts",
        "displayName": "%languageModelTools.listHosts.displayName%",
        "modelDescription": "%languageModelTools.listHosts.modelDescription%",
        "userDescription": "%languageModelTools.listHosts.userDescription%",
        "canBeReferencedInPrompt": true,
        "icon": "$(server)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Optional space-separated terms. Every term must match at least one host field: name, address, username, group, port, or tags.",
              "maxLength": 200
            },
            "limit": {
              "type": "integer",
              "description": "Maximum number of hosts to return. Defaults to 50 and is capped at 200.",
              "minimum": 1,
              "maximum": 200
            },
            "offset": {
              "type": "integer",
              "description": "Zero-based result offset for pagination. Use nextOffset from a previous result.",
              "minimum": 0
            },
            "includeIdentityFilePath": {
              "type": "boolean",
              "description": "Include associated private key file paths. Private key contents are never returned."
            }
          },
          "additionalProperties": false
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshKit",
          "title": "%viewsContainers.title%",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "sshKit": [
        {
          "id": "sshKit.hosts",
          "name": "%views.hosts%",
          "icon": "$(server)"
        },
        {
          "id": "sshKit.keys",
          "name": "%views.keys%",
          "icon": "$(key)"
        }
      ]
    },
    "commands": [
      {
        "command": "sshKit.addHost",
        "title": "%commands.addHost%",
        "category": "%commands.category%",
        "icon": "$(add)"
      },
      {
        "command": "sshKit.addGroup",
        "title": "%commands.addGroup%",
        "category": "%commands.category%",
        "icon": "$(new-folder)"
      },
      {
        "command": "sshKit.refresh",
        "title": "%commands.refresh%",
        "category": "%commands.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "sshKit.connectHostInCurrentWindow",
        "title": "%commands.connectHostInCurrentWindow%",
        "category": "%commands.category%",
        "icon": "$(window)"
      },
      {
        "command": "sshKit.connectHostInNewWindow",
        "title": "%commands.connectHostInNewWindow%",
        "category": "%commands.category%",
        "icon": "$(empty-window)"
      },
      {
        "command": "sshKit.connectInExternalTerminal",
        "title": "%commands.connectInTerminal%",
        "category": "%commands.category%",
        "icon": "$(terminal)"
      },
      {
        "command": "sshKit.editHost",
        "title": "%commands.editHost%",
        "category": "%commands.category%",
        "icon": "$(edit)"
      },
      {
        "command": "sshKit.deleteHost",
        "title": "%commands.deleteHost%",
        "category": "%commands.category%",
        "icon": "$(trash)"
      },
      {
        "command": "sshKit.renameGroup",
        "title": "%commands.renameGroup%",
        "category": "%commands.category%",
        "icon": "$(edit)"
      },
      {
        "command": "sshKit.deleteGroup",
        "title": "%commands.deleteGroup%",
        "category": "%commands.category%",
        "icon": "$(trash)"
      },
      {
        "command": "sshKit.moveGroupTop",
        "title": "%commands.moveGroupTop%",
        "category": "%commands.category%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "sshKit.moveGroupUp",
        "title": "%commands.moveGroupUp%",
        "category": "%commands.category%",
        "icon": "$(chevron-up)"
      },
      {
        "command": "sshKit.moveGroupDown",
        "title": "%commands.moveGroupDown%",
        "category": "%commands.category%",
        "icon": "$(chevron-down)"
      },
      {
        "command": "sshKit.moveGroupBottom",
        "title": "%commands.moveGroupBottom%",
        "category": "%commands.category%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "sshKit.sortGroupsByName",
        "title": "%commands.sortGroupsByName%",
        "category": "%commands.category%",
        "icon": "$(list-ordered)",
        "enablement": "!sshKit.hostFilterActive"
      },
      {
        "command": "sshKit.copyHostName",
        "title": "%commands.copyHostName%",
        "category": "%commands.category%",
        "icon": "$(copy)"
      },
      {
        "command": "sshKit.copyHostDetail",
        "title": "%commands.copyHostDetail%",
        "category": "%commands.category%",
        "icon": "$(copy)"
      },
      {
        "command": "sshKit.testConnection",
        "title": "%commands.testConnection%",
        "category": "%commands.category%",
        "icon": "$(pulse)"
      },
      {
        "command": "sshKit.importConfig",
        "title": "%commands.importConfig%",
        "category": "%commands.category%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "sshKit.exportConfig",
        "title": "%commands.exportConfig%",
        "category": "%commands.category%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "sshKit.searchHosts",
        "title": "%commands.searchHosts%",
        "category": "%commands.category%"
      },
      {
        "command": "sshKit.filterHosts",
        "title": "%commands.filterHosts%",
        "category": "%commands.category%",
        "icon": "$(search)"
      },
      {
        "command": "sshKit.clearHostFilter",
        "title": "%commands.clearHostFilter%",
        "category": "%commands.category%",
        "icon": "$(clear-all)",
        "enablement": "sshKit.hostFilterActive"
      },
      {
        "command": "sshKit.sortHosts",
        "title": "%commands.sortHosts%",
        "category": "%commands.category%",
        "icon": "$(list-ordered)"
      },
      {
        "command": "sshKit.openSshConfig",
        "title": "%commands.openSshConfig%",
        "category": "%commands.category%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "sshKit.cleanupAliases",
        "title": "%commands.cleanupAliases%",
        "category": "%commands.category%",
        "icon": "$(clear-all)"
      },
      {
        "command": "sshKit.listKeys",
        "title": "%commands.listKeys%",
        "category": "%commands.category%",
        "icon": "$(key)"
      },
      {
        "command": "sshKit.generateKey",
        "title": "%commands.generateKey%",
        "category": "%commands.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "sshKit.deduplicateHosts",
        "title": "%commands.deduplicateHosts%",
        "category": "%commands.category%",
        "icon": "$(clear-all)"
      },
      {
        "command": "sshKit.batchDeleteHosts",
        "title": "%commands.batchDeleteHosts%",
        "category": "%commands.category%",
        "icon": "$(trash)"
      },
      {
        "command": "sshKit.batchChangeHostKey",
        "title": "%commands.batchChangeHostKey%",
        "category": "%commands.category%",
        "icon": "$(key)"
      },
      {
        "command": "sshKit.changeHostKey",
        "title": "%commands.changeHostKey%",
        "category": "%commands.category%",
        "icon": "$(key)"
      },
      {
        "command": "sshKit.backupData",
        "title": "%commands.backupData%",
        "category": "%commands.category%",
        "icon": "$(save)"
      },
      {
        "command": "sshKit.restoreData",
        "title": "%commands.restoreData%",
        "category": "%commands.category%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "sshKit.copyKeyPublic",
        "title": "%commands.copyKeyPublic%",
        "category": "%commands.category%",
        "icon": "$(copy)"
      },
      {
        "command": "sshKit.copyKeyDetail",
        "title": "%commands.copyKeyDetail%",
        "category": "%commands.category%",
        "icon": "$(copy)"
      },
      {
        "command": "sshKit.regenerateKeyPublic",
        "title": "%commands.regenerateKeyPublic%",
        "category": "%commands.category%",
        "icon": "$(sync)"
      },
      {
        "command": "sshKit.deleteKey",
        "title": "%commands.deleteKey%",
        "category": "%commands.category%",
        "icon": "$(trash)"
      },
      {
        "command": "sshKit.renameKey",
        "title": "%commands.renameKey%",
        "category": "%commands.category%",
        "icon": "$(edit)"
      },
      {
        "command": "sshKit.showKeyDetail",
        "title": "%commands.showKeyDetail%",
        "category": "%commands.category%",
        "icon": "$(info)"
      },
      {
        "command": "sshKit.openKeyFile",
        "title": "%commands.openKeyFile%",
        "category": "%commands.category%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "sshKit.openPrivateKey",
        "title": "%commands.openPrivateKey%",
        "category": "%commands.category%",
        "icon": "$(lock)"
      },
      {
        "command": "sshKit.showCurrentConnection",
        "title": "%commands.showCurrentConnection%",
        "category": "%commands.category%",
        "icon": "$(remote)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "sshKit.hosts",
        "contents": "%viewsWelcome.hosts%"
      },
      {
        "view": "sshKit.keys",
        "contents": "%viewsWelcome.keys%"
      }
    ],
    "submenus": [
      {
        "id": "sshKit.groupOrder",
        "label": "%menus.groupOrder%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sshKit.addGroup",
          "when": "view == sshKit.hosts",
          "group": "navigation@1"
        },
        {
          "command": "sshKit.addHost",
          "when": "view == sshKit.hosts",
          "group": "navigation@2"
        },
        {
          "command": "sshKit.importConfig",
          "when": "view == sshKit.hosts",
          "group": "navigation@3"
        },
        {
          "command": "sshKit.exportConfig",
          "when": "view == sshKit.hosts",
          "group": "navigation@4"
        },
        {
          "command": "sshKit.openSshConfig",
          "when": "view == sshKit.hosts",
          "group": "navigation@5"
        },
        {
          "command": "sshKit.sortHosts",
          "when": "view == sshKit.hosts",
          "group": "navigation@6"
        },
        {
          "command": "sshKit.filterHosts",
          "when": "view == sshKit.hosts",
          "group": "navigation@7"
        },
        {
          "command": "sshKit.clearHostFilter",
          "when": "view == sshKit.hosts && sshKit.hostFilterActive",
          "group": "navigation@8"
        },
        {
          "command": "sshKit.refresh",
          "when": "view == sshKit.hosts",
          "group": "navigation@9"
        },
        {
          "command": "sshKit.sortGroupsByName",
          "when": "view == sshKit.hosts && !sshKit.hostFilterActive",
          "group": "1_sort@1"
        },
        {
          "command": "sshKit.deduplicateHosts",
          "when": "view == sshKit.hosts",
          "group": "2_io@1"
        },
        {
          "command": "sshKit.batchDeleteHosts",
          "when": "view == sshKit.hosts",
          "group": "2_io@2"
        },
        {
          "command": "sshKit.batchChangeHostKey",
          "when": "view == sshKit.hosts",
          "group": "2_io@3"
        },
        {
          "command": "sshKit.backupData",
          "when": "view == sshKit.hosts",
          "group": "2_io@4"
        },
        {
          "command": "sshKit.restoreData",
          "when": "view == sshKit.hosts",
          "group": "2_io@5"
        },
        {
          "command": "sshKit.cleanupAliases",
          "when": "view == sshKit.hosts",
          "group": "2_io@6"
        },
        {
          "command": "sshKit.generateKey",
          "when": "view == sshKit.keys",
          "group": "navigation"
        },
        {
          "command": "sshKit.refresh",
          "when": "view == sshKit.keys",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sshKit.connectHostInCurrentWindow",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "inline@1"
        },
        {
          "command": "sshKit.connectHostInNewWindow",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "inline@2"
        },
        {
          "command": "sshKit.connectInExternalTerminal",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "inline@3"
        },
        {
          "command": "sshKit.editHost",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "1_modify@1"
        },
        {
          "command": "sshKit.changeHostKey",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "1_modify@2"
        },
        {
          "command": "sshKit.deleteHost",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "1_modify@3"
        },
        {
          "command": "sshKit.copyHostName",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "2_info"
        },
        {
          "command": "sshKit.copyHostDetail",
          "when": "view == sshKit.hosts && viewItem == hostDetail",
          "group": "2_info"
        },
        {
          "command": "sshKit.testConnection",
          "when": "view == sshKit.hosts && viewItem == host",
          "group": "2_info"
        },
        {
          "command": "sshKit.renameGroup",
          "when": "view == sshKit.hosts && viewItem == group",
          "group": "1_modify@1"
        },
        {
          "command": "sshKit.moveGroupUp",
          "when": "view == sshKit.hosts && viewItem == group && !sshKit.hostFilterActive",
          "group": "inline@1"
        },
        {
          "command": "sshKit.moveGroupDown",
          "when": "view == sshKit.hosts && viewItem == group && !sshKit.hostFilterActive",
          "group": "inline@2"
        },
        {
          "submenu": "sshKit.groupOrder",
          "when": "view == sshKit.hosts && viewItem == group && !sshKit.hostFilterActive",
          "group": "1_modify@2"
        },
        {
          "command": "sshKit.deleteGroup",
          "when": "view == sshKit.hosts && viewItem == group",
          "group": "1_modify@3"
        },
        {
          "command": "sshKit.copyKeyPublic",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "inline"
        },
        {
          "command": "sshKit.regenerateKeyPublic",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "inline@2"
        },
        {
          "command": "sshKit.renameKey",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "1_modify"
        },
        {
          "command": "sshKit.deleteKey",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "1_modify"
        },
        {
          "command": "sshKit.openPrivateKey",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "2_info"
        },
        {
          "command": "sshKit.showKeyDetail",
          "when": "view == sshKit.keys && viewItem == key",
          "group": "2_info"
        },
        {
          "command": "sshKit.copyKeyDetail",
          "when": "view == sshKit.keys && viewItem == keyDetail",
          "group": "inline"
        }
      ],
      "sshKit.groupOrder": [
        {
          "command": "sshKit.moveGroupTop",
          "group": "navigation@1"
        },
        {
          "command": "sshKit.moveGroupUp",
          "group": "navigation@2"
        },
        {
          "command": "sshKit.moveGroupDown",
          "group": "navigation@3"
        },
        {
          "command": "sshKit.moveGroupBottom",
          "group": "navigation@4"
        },
        {
          "command": "sshKit.sortGroupsByName",
          "group": "sort@1"
        }
      ],
      "commandPalette": [
        {
          "command": "sshKit.connectHostInCurrentWindow",
          "when": "false"
        },
        {
          "command": "sshKit.connectHostInNewWindow",
          "when": "false"
        },
        {
          "command": "sshKit.connectInExternalTerminal",
          "when": "false"
        },
        {
          "command": "sshKit.editHost",
          "when": "false"
        },
        {
          "command": "sshKit.deleteHost",
          "when": "false"
        },
        {
          "command": "sshKit.changeHostKey",
          "when": "false"
        },
        {
          "command": "sshKit.renameGroup",
          "when": "false"
        },
        {
          "command": "sshKit.deleteGroup",
          "when": "false"
        },
        {
          "command": "sshKit.moveGroupTop",
          "when": "false"
        },
        {
          "command": "sshKit.moveGroupUp",
          "when": "false"
        },
        {
          "command": "sshKit.moveGroupDown",
          "when": "false"
        },
        {
          "command": "sshKit.moveGroupBottom",
          "when": "false"
        },
        {
          "command": "sshKit.copyHostName",
          "when": "false"
        },
        {
          "command": "sshKit.copyHostDetail",
          "when": "false"
        },
        {
          "command": "sshKit.testConnection",
          "when": "false"
        },
        {
          "command": "sshKit.copyKeyPublic",
          "when": "false"
        },
        {
          "command": "sshKit.copyKeyDetail",
          "when": "false"
        },
        {
          "command": "sshKit.deleteKey",
          "when": "false"
        },
        {
          "command": "sshKit.renameKey",
          "when": "false"
        },
        {
          "command": "sshKit.showKeyDetail",
          "when": "false"
        },
        {
          "command": "sshKit.openKeyFile",
          "when": "false"
        },
        {
          "command": "sshKit.openPrivateKey",
          "when": "false"
        },
        {
          "command": "sshKit.showCurrentConnection",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "preflight": "npm run lint && npm run check:l10n && npm run package && npm run check:runtime && node scripts/preflight.mjs",
    "vsix": "vsce package --no-dependencies",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "check:runtime": "node scripts/check-runtime-behavior.mjs",
    "check:l10n": "node scripts/generate-l10n.mjs --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.15": "1.1.16",
      "brace-expansion@5.0.6": "5.0.7",
      "js-yaml@4.2.0": "4.3.0",
      "shell-quote@1.8.4": "1.9.0"
    }
  }
}
